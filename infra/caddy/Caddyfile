{$CADDY_SITE_ADDRESS::80} {
  encode zstd gzip
  root * /srv/scancontact
  log {
    output stdout
    format console
  }

  header {
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "camera=(), microphone=(self), geolocation=()"
    -Server
  }

  handle_path /api/* {
    reverse_proxy api:4000
  }

  respond /healthz 200

  handle /admin/tags/new* {
    try_files {path} {path}/ /admin/tags/new/
    file_server
  }

  handle /admin/tags/* {
    rewrite * /admin/tags/__tagId__/
    file_server
  }

  handle /admin/owners/* {
    rewrite * /admin/owners/__ownerId__/
    file_server
  }

  handle /dashboard/tags/* {
    rewrite * /dashboard/tags/__id__/
    file_server
  }

  handle /t/* {
    rewrite * /t/__slug__/
    file_server
  }

  handle /c/* {
    rewrite * /c/__id__/
    file_server
  }

  handle /call/* {
    rewrite * /call/__id__/
    file_server
  }

  handle {
    try_files {path} {path}/ /admin/
    file_server
  }
}
