# Example dart-defines for local development.
# Debug builds fall back to these Android emulator URLs when omitted.
APP_NAME=NoNumQR Owner
API_BASE_URL=http://10.0.2.2:4000
WEB_BASE_URL=http://10.0.2.2:3000
ENVIRONMENT=development
ENABLE_PUSH=true
ENABLE_ANALYTICS=false
DEFAULT_LANGUAGE=en

# Physical Android device debug example:
# API_BASE_URL=http://YOUR_PC_IP:4000
# WEB_BASE_URL=http://YOUR_PC_IP:3000

# Production release example:
# ENVIRONMENT=production
# API_BASE_URL=https://api.nonumqr.com
# WEB_BASE_URL=https://nonumqr.com
# NONUMQR_APPLICATION_ID=com.yourcompany.nonumqr.owner
