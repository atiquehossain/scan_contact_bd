# Root compose defaults for local development.
COMPOSE_PROJECT_NAME=nonumqr
POSTGRES_DB=nonumqr
POSTGRES_USER=nonumqr
POSTGRES_PASSWORD=nonumqr_local_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://nonumqr:nonumqr_local_password@postgres:5432/nonumqr?schema=public
REDIS_PORT=6379
API_REDIS_URL=
APP_DOMAIN=localhost
CADDY_SITE_ADDRESS=:80
WEB_HTTP_PORT=3000
WEB_HTTPS_PORT=3443
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=NoNumQR
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=/api
STATIC_NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_DEV_ADMIN_EMAIL=
NEXT_ALLOWED_DEV_ORIGINS=
API_NODE_OPTIONS=--max-old-space-size=384
